<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hyperpass.mapper.HospitalPatientMappingMapper">

    <resultMap id="mappingResultMap" type="com.hyperpass.domain.HospitalPatientMapping">
        <id     property="id"           column="id"/>
        <result property="patientId"    column="patient_id"/>
        <result property="hisPatientNo" column="his_patient_no"/>
        <result property="hospitalCode" column="hospital_code"/>
        <result property="createdAt"    column="created_at"/>
    </resultMap>

    <select id="findByPatientIdAndHospitalCode" resultMap="mappingResultMap">
        SELECT id, patient_id, his_patient_no, hospital_code, created_at
        FROM hospital_patient_mapping
        WHERE patient_id = #{patientId}
        <if test="hospitalCode != null">
            AND hospital_code = #{hospitalCode}
        </if>
    </select>

    <insert id="insert" parameterType="com.hyperpass.domain.HospitalPatientMapping"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO hospital_patient_mapping (patient_id, his_patient_no, hospital_code)
        VALUES (#{patientId}, #{hisPatientNo}, #{hospitalCode})
    </insert>

</mapper>
